# Copy this to backend/.env and fill in real values.
# Never commit backend/.env to GitHub.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/watchr?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.xxxxx.mongodb.net/watchr

# Long random string — generate one at https://randomkeygen.com
JWT_SECRET=replace_with_a_long_random_string_minimum_32_characters

# From https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Frontend origin allowed by CORS
# Development:
CLIENT_URL=http://localhost:5173
# Production (set this in Render dashboard, not here):
# CLIENT_URL=https://watchrbynhloso.vercel.app
